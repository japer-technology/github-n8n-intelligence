    {
      "id": "dbd1e49a-e6ca-4af2-8cef-888e9e694c12",
      "name": "Code (Match Birthday 'Date and Month')",
      "type": "n8n-nodes-base.code",
      "position": [
        832,
        304
      ],
      "parameters": {
        "jsCode": "// Get today's date as JS Date\nconst today = new Date();\n\n// Extract day and month in dd/MM format\nconst todayDay = String(today.getDate()).padStart(2, '0');      // \"28\"\nconst todayMonth = String(today.getMonth() + 1).padStart(2, '0'); // \"03\"\nconst todayStr = `${todayDay}/${todayMonth}`;                   // \"28/03\"\n\n// Map over all contacts\nconst newItems = $input.all().map(item => {\n  const birthdayStr = item.json.birthdays; // e.g. \"mm/dd/yyyy\"\n\n  if (!birthdayStr) return { json: { birthdayToday: \"No\" } };\n\n  // Parse string into day/month\n  const dateParts = birthdayStr.split('/'); // [\"3\",\"28\",\"1999\"]\n  const month = dateParts[0].padStart(2, '0'); // \"mm\"\n  const day = dateParts[1].padStart(2, '0');   // \"dd\"\n  const birthDayFormatted = `${day}/${month}`;  // \"dd/mm\"\n\n  // Compare with today's date\n  const isToday = birthDayFormatted === todayStr ? \"YES\" : \"NO\";\n\n  return {\n    json: {\n      birthdayToday: isToday\n    }\n  };\n});\n\nreturn newItems;"
      },
      "typeVersion": 2
    },
