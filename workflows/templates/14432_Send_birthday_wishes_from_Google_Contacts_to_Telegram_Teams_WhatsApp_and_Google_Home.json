    {
      "id": "08f7cdd1-b9e9-45a3-8432-88526d786ab0",
      "name": "Code (Get & Clean Phone Number)",
      "type": "n8n-nodes-base.code",
      "position": [
        1712,
        288
      ],
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\n// Get numbers array safely\nconst numbers = Object.values(data?.phoneNumbers ?? {})[0] ?? [];\n\n// Clean numbers\nconst cleanedNumbers = numbers.map(num =>\n  String(num).replace(/\\D/g, \"\")\n);\n\nreturn [\n  {\n    json: {\n      phoneNumbers: cleanedNumbers\n    }\n  }\n];"
      },
      "typeVersion": 2
    },
